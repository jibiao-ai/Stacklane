# Stacklane Environment Configuration
# ============================================================
# PASSWORD POLICY: All passwords must meet the following requirements:
#   - Minimum 9 characters
#   - At least one uppercase letter (A-Z)
#   - At least one lowercase letter (a-z)
#   - At least one digit (0-9)
#   - At least one special character (!@#$%^&*()-_=+)
# ============================================================

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=stacklane
DB_PASSWORD=Stack@Db2026!
DB_NAME=stacklane

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=Redis@Stack2026!

# JWT Configuration (change in production!)
JWT_SECRET=Jwt@Stacklane#Secret2026!

# Server Configuration
SERVER_PORT=8080

# GPUStack Integration (optional)
# GPUSTACK_URL=http://your-gpustack-server:8080
# GPUSTACK_API_KEY=your-api-key

# ============================================================
# Default Admin Account (created on first startup):
#   Username: admin
#   Password: Admin@2026!
#   Email:    admin@stacklane.io
#   Role:     admin
# ============================================================
